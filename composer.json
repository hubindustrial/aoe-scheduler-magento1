{
  "name": "aoepeople/aoe_scheduler",
  "license": "GPL-3.0",
  "type": "magento-module",
  "description": "Magento Cron Scheduler",
  "homepage": "https://github.com/AOEpeople/Aoe_Scheduler",
  "require": {
    "php": "^8.0",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-posix": "*",
    "magento-hackathon/magento-composer-installer": "*"
  },
  "require-dev": {
    "aydin-hassan/magento-core-composer-installer": "~2.1.0",
    "colinmollenhour/modman": "1.14",
    "phpunit/phpunit": "^9.6",
    "openmage/magento-lts": "^20.0.0"
  },
  "authors": [
    {
      "name": "Fabrizio Branca",
      "email": "firstname.lastname@aoe.com",
      "role": "Author/Maintainer"
    },
    {
      "name": "Lee Saferite",
      "email": "lee.saferite@aoe.com",
      "role": "Contributor/Maintainer"
    }
  ],
  "replace": {
    "fbrnc/aoe_scheduler": "*"
  },
  "config": {
    "allow-plugins": {
      "magento-hackathon/magento-composer-installer": true,
      "aydin-hassan/magento-core-composer-installer": true,
      "cweagans/composer-patches": true
    }
  },
  "extra": {
    "magento-root-dir": "htdocs",
    "enable-patching": true,
    "magento-core-package-type": "magento-source"
  }
}
